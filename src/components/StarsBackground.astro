---
// Cosmic starfield background using tsparticles.
// Rendered on the client; hidden when prefers-reduced-motion is active (CSS).
---

<div id="stars" class="fixed inset-0 -z-10 pointer-events-none bg-black" aria-hidden="true"></div>

<style>
  @media (prefers-reduced-motion: reduce) {
    #stars {
      background:
        radial-gradient(1px 1px at 10% 20%, rgba(255, 255, 255, 0.6) 50%, transparent 50%),
        radial-gradient(1px 1px at 30% 60%, rgba(255, 255, 255, 0.5) 50%, transparent 50%),
        radial-gradient(1px 1px at 70% 30%, rgba(255, 255, 255, 0.7) 50%, transparent 50%),
        radial-gradient(1px 1px at 85% 75%, rgba(255, 255, 255, 0.5) 50%, transparent 50%),
        #000;
    }
  }
</style>

<script>
  import { tsParticles } from "@tsparticles/engine";
  import { loadSlim } from "@tsparticles/slim";

  const mq = window.matchMedia("(prefers-reduced-motion: reduce)");
  if (!mq.matches) {
    (async () => {
      await loadSlim(tsParticles);
      await tsParticles.load({
        id: "stars",
        options: {
          fullScreen: { enable: false },
          background: { color: { value: "#000000" } },
          fpsLimit: 60,
          detectRetina: true,
          particles: {
            number: { value: 140, density: { enable: true, width: 1920, height: 1080 } },
            color: { value: "#ffffff" },
            shape: { type: "circle" },
            opacity: {
              value: { min: 0.1, max: 0.9 },
              animation: { enable: true, speed: 0.6, sync: false },
            },
            size: { value: { min: 0.3, max: 1.6 } },
            move: {
              enable: true,
              speed: 0.15,
              direction: "none",
              random: true,
              straight: false,
              outModes: { default: "out" },
            },
          },
          interactivity: {
            events: {
              onHover: { enable: true, mode: "bubble" },
              resize: { enable: true },
            },
            modes: {
              bubble: { distance: 120, size: 2.2, duration: 2, opacity: 1 },
            },
          },
        },
      });
    })();
  }
</script>
