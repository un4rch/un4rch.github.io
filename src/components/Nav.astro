---
// Fixed top nav: cursive logo + burger (placeholder for future drawer).
---

<nav class="fixed top-0 inset-x-0 z-30 flex items-center justify-between px-6 py-5 md:px-10 md:py-6">
  <a href="/" class="logo text-2xl md:text-3xl tracking-wide text-white/95 hover:text-white transition-colors">
    Unai
  </a>
  <button type="button" class="burger" aria-label="Open menu">
    <span></span>
    <span></span>
  </button>
</nav>

<style>
  .logo {
    font-family: var(--font-script);
    font-weight: 700;
    letter-spacing: 0.01em;
  }
  .burger {
    width: 36px;
    height: 36px;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    gap: 6px;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .burger span {
    display: block;
    height: 1.5px;
    background: rgba(255, 255, 255, 0.85);
    transition: width 0.25s ease, background-color 0.25s ease;
  }
  .burger span:nth-child(1) {
    width: 24px;
  }
  .burger span:nth-child(2) {
    width: 16px;
  }
  .burger:hover span {
    background: #fff;
    width: 24px;
  }
</style>
